<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/topAppBar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:layout_marginTop="32dp"
                android:background="#F8F9FB"
                android:elevation="0dp"
                app:contentInsetStart="16dp"> <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:orientation="horizontal"
                android:gravity="center_vertical">

            <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/logo_kecil"
                    android:scaleType="fitCenter" />

            <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="UniLink"
                    android:textColor="#005EA4"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />
        </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_gravity="end"
                    android:layout_marginEnd="16dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp">

                <ImageView
                        android:id="@+id/ivProfile"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@drawable/foto_stevan" />
            </com.google.android.material.card.MaterialCardView>

        </com.google.android.material.appbar.MaterialToolbar>

        <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="20dp">

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="32dp">

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="THE DIGITAL QUAD"
                        android:textSize="10sp"
                        android:textColor="#005EA4"
                        android:textStyle="bold"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="8dp" />

                <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Academic Pulse"
                        android:textSize="32sp"
                        android:textColor="#191C1E"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="8dp" />

                <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Your collaborative ecosystem for growth and connection."
                        android:textSize="16sp"
                        android:textColor="#404752"
                        android:layout_marginBottom="20dp" />

                <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:startIconDrawable="@drawable/ic_search"
                        app:startIconTint="#707783"
                        app:boxCornerRadiusBottomEnd="24dp"
                        app:boxCornerRadiusBottomStart="24dp"
                        app:boxCornerRadiusTopEnd="24dp"
                        app:boxCornerRadiusTopStart="24dp"
                        app:boxBackgroundColor="#E0E3E5"
                        app:boxStrokeColor="@android:color/transparent">

                    <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Search internships, peers, or research..."
                            android:textSize="14sp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="14dp"
                            android:paddingBottom="14dp" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="24dp">

                <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingEnd="8dp">

                    <com.google.android.material.chip.Chip
                            android:id="@+id/chipAll"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:text="All Posts"
                            android:textColor="@android:color/white"
                            app:chipBackgroundColor="#005EA4"
                            app:chipStrokeColor="@android:color/transparent" />

                    <com.google.android.material.chip.Chip
                            android:id="@+id/chipInternships"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:text="Internships"
                            app:chipBackgroundColor="#E6E8EA"
                            app:chipStrokeColor="@android:color/transparent" />

                    <com.google.android.material.chip.Chip
                            android:id="@+id/chipResearch"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:text="Research"
                            app:chipBackgroundColor="#E6E8EA"
                            app:chipStrokeColor="@android:color/transparent" />

                    <com.google.android.material.chip.Chip
                            android:id="@+id/chipClubs"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="10dp"
                            android:text="Clubs"
                            app:chipBackgroundColor="#E6E8EA"
                            app:chipStrokeColor="@android:color/transparent" />

                    <com.google.android.material.chip.Chip
                            android:id="@+id/chipFeatured"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Featured"
                            app:chipBackgroundColor="#FFE087"
                            app:chipStrokeColor="@android:color/transparent" />
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@android:color/white"
                        app:strokeWidth="0dp">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">

                            <ImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:src="@drawable/ic_company"
                                    android:background="#F2F4F6"
                                    android:padding="8dp"
                                    android:layout_marginEnd="12dp" />

                            <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="TechNova Solutions"
                                        android:textSize="16sp"
                                        android:textStyle="bold"
                                        android:textColor="#191C1E" />

                                <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Hiring Now"
                                        android:textSize="10sp"
                                        android:textColor="#404752"
                                        android:letterSpacing="0.1" />
                            </LinearLayout>

                            <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Internship"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:background="#D3E4FF"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:paddingTop="4dp"
                                    android:paddingBottom="4dp"
                                    android:textColor="#004881" />
                        </LinearLayout>

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Internship UI Designer"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#191C1E"
                                android:layout_marginBottom="8dp" />

                        <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Join our design team to revolutionize educational technology. You'll work directly with senior designers on scalable Material 3 systems and user research for our upcoming campus suite."
                                android:textSize="14sp"
                                android:textColor="#404752"
                                android:layout_marginBottom="16dp"
                                android:lineSpacingExtra="4dp" />

                        <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:background="#98F994"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="8dp"
                                android:paddingBottom="8dp"
                                android:layout_marginBottom="16dp"
                                android:gravity="center_vertical">

                            <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_school"
                                    android:layout_marginEnd="8dp" />

                            <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="12 alumni work here"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#005313" />
                        </LinearLayout>

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingTop="16dp">

                            <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="horizontal">

                                <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:src="@drawable/ic_avatar_placeholder"
                                        android:background="@drawable/avatar_border" />

                                <ImageView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:src="@drawable/ic_avatar_placeholder"
                                        android:background="@drawable/avatar_border"
                                        android:layout_marginStart="-12dp" />

                                <TextView
                                        android:layout_width="32dp"
                                        android:layout_height="32dp"
                                        android:background="@drawable/avatar_plus"
                                        android:gravity="center"
                                        android:text="+8"
                                        android:textSize="10sp"
                                        android:textStyle="bold"
                                        android:textColor="#191C1E"
                                        android:layout_marginStart="-12dp" />
                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Apply Now"
                                    android:textAllCaps="false"
                                    app:cornerRadius="24dp"
                                    android:paddingStart="24dp"
                                    android:paddingEnd="24dp"
                                    android:paddingTop="10dp"
                                    android:paddingBottom="10dp"
                                    app:backgroundTint="#005EA4" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">

                            <ImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:src="@drawable/ic_avatar_placeholder"
                                    android:background="#F2F4F6"
                                    android:padding="8dp"
                                    android:layout_marginEnd="12dp" />

                            <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Alex Rivera"
                                        android:textSize="16sp"
                                        android:textStyle="bold"
                                        android:textColor="#191C1E" />

                                <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Physics Senior"
                                        android:textSize="10sp"
                                        android:textColor="#404752"
                                        android:letterSpacing="0.1" />
                            </LinearLayout>

                            <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Collaboration"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:background="#98F994"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:paddingTop="4dp"
                                    android:paddingBottom="4dp"
                                    android:textColor="#0C7521" />
                        </LinearLayout>

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Renewable Energy Research"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#191C1E"
                                android:layout_marginBottom="8dp" />

                        <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Looking for 2 Engineering students to help build a small-scale solar tracking prototype. We have lab access and materials; just need more hands for the assembly and testing phase."
                                android:textSize="14sp"
                                android:textColor="#404752"
                                android:layout_marginBottom="16dp"
                                android:lineSpacingExtra="4dp" />

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingTop="16dp">

                            <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal"
                                        android:gravity="center_vertical"
                                        android:layout_marginEnd="16dp">

                                    <ImageView
                                            android:layout_width="20dp"
                                            android:layout_height="20dp"
                                            android:src="@drawable/ic_favorite"
                                            android:layout_marginEnd="4dp" />

                                    <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="45"
                                            android:textSize="14sp" />
                                </LinearLayout>

                                <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal"
                                        android:gravity="center_vertical">

                                    <ImageView
                                            android:layout_width="20dp"
                                            android:layout_height="20dp"
                                            android:src="@drawable/ic_chat"
                                            android:layout_marginEnd="4dp" />

                                    <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:text="12"
                                            android:textSize="14sp" />
                                </LinearLayout>
                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Join Project"
                                    android:textAllCaps="false"
                                    app:cornerRadius="24dp"
                                    android:paddingStart="24dp"
                                    android:paddingEnd="24dp"
                                    android:paddingTop="10dp"
                                    android:paddingBottom="10dp"
                                    app:backgroundTint="#E6E8EA"
                                    app:strokeColor="#C0C7D4"
                                    app:strokeWidth="0dp" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="2dp"
                        app:cardBackgroundColor="@android:color/white">

                    <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="20dp">

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="12dp">

                            <ImageView
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:src="@drawable/ic_avatar_placeholder"
                                    android:background="#F2F4F6"
                                    android:padding="8dp"
                                    android:layout_marginEnd="12dp" />

                            <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Dr. Sarah Jenkins"
                                        android:textSize="16sp"
                                        android:textStyle="bold"
                                        android:textColor="#191C1E" />

                                <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Alumni '18 | Data Science"
                                        android:textSize="10sp"
                                        android:textColor="#404752"
                                        android:letterSpacing="0.1" />
                            </LinearLayout>

                            <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Mentorship"
                                    android:textSize="11sp"
                                    android:textStyle="bold"
                                    android:background="#FFE087"
                                    android:paddingStart="12dp"
                                    android:paddingEnd="12dp"
                                    android:paddingTop="4dp"
                                    android:paddingBottom="4dp"
                                    android:textColor="#4F3E00" />
                        </LinearLayout>

                        <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Career Path: Machine Learning"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#191C1E"
                                android:layout_marginBottom="8dp" />

                        <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Hosting a 1-on-1 coffee chat session for juniors interested in entering the ML field. I'll share my journey from UniLink to lead researcher at GlobalAI."
                                android:textSize="14sp"
                                android:textColor="#404752"
                                android:layout_marginBottom="16dp"
                                android:lineSpacingExtra="4dp" />

                        <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:background="#FFE087"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:paddingTop="8dp"
                                android:paddingBottom="8dp"
                                android:layout_marginBottom="16dp"
                                android:gravity="center_vertical">

                            <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:src="@drawable/ic_star"
                                    android:layout_marginEnd="8dp" />

                            <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Top Contributor"
                                    android:textSize="12sp"
                                    android:textStyle="bold"
                                    android:textColor="#4F3E00" />
                        </LinearLayout>

                        <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingTop="16dp">

                            <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="Starts in 3 days"
                                    android:textSize="12sp"
                                    android:textColor="#404752" />

                            <com.google.android.material.button.MaterialButton
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Book Spot"
                                    android:textAllCaps="false"
                                    app:cornerRadius="24dp"
                                    android:paddingStart="24dp"
                                    android:paddingEnd="24dp"
                                    android:paddingTop="10dp"
                                    android:paddingBottom="10dp"
                                    app:backgroundTint="#005EA4" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>